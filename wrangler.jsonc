{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vitina-road",
  "main": "worker.js",
  "compatibility_date": "2026-07-23",
  "assets": {
    "directory": "./worker-assets",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/health"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vitina-road-db",
      "database_id": "4d807527-f89f-4f63-bf63-6d99bd27f47e"
    }
  ]
}
